datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// schema.prisma

generator client {
  provider = "prisma-client-js"
}

model Staff {
  id                      String         @id @default(uuid())
  email                   String         @unique
  password                String
  name                    String
  role                    Role
  venueManagerAssignments VenueManager[]
  dutyManagerAssignments  DutyManager[]
  bansCreated             Ban[]          @relation("BanCreator")
}

enum Role {
  ADMIN
  VENUE_MANAGER
  DUTY_MANAGER
  BOUNCER
}

// ============================================
// VENUES
// ============================================

model Venue {
  id        String @id @default(uuid())
  name      String
  imagePath String
  address   String
  phone     String

  // Relationships
  venueManagers VenueManager[]
  dutyManagers  DutyManager[]
  venueBans     VenueBan[]
}

// Many-to-many: Venue Managers can manage multiple venues
model VenueManager {
  id      String @id @default(uuid())
  userId  String
  venueId String

  staff Staff @relation(fields: [userId], references: [id], onDelete: Cascade)
  venue Venue @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@unique([userId, venueId])
}

// Many-to-many: Duty Managers can be assigned to multiple venues (view only)
model DutyManager {
  id      String @id @default(uuid())
  userId  String
  venueId String

  staff Staff @relation(fields: [userId], references: [id], onDelete: Cascade)
  venue Venue @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@unique([userId, venueId])
}

// ============================================
// PEOPLE (BANNED INDIVIDUALS)
// ============================================

model BannedPerson {
  id        String @id @default(uuid())
  name      String
  imagePath String
  bans      Ban[]
}

// ============================================
// BANS
// ============================================

model Ban {
  id              String      @id @default(uuid())
  personId        String
  createdById     String
  reason          String
  notes           String?
  startDate    DateTime    @default(now()) // When the incident occurred
  duration BanDuration // 1, 3, 6 months, 1 or 2 years

  // Ban type and scope
  isBlanketBan Boolean @default(false) // True = applies to all venues, False = specific venues
  status BanStatus @default(PENDING)

  // Relationships
  person    BannedPerson @relation(fields: [personId], references: [id], onDelete: Cascade)
  createdBy Staff        @relation("BanCreator", fields: [createdById], references: [id])
  venueBans VenueBan[] // Individual venue-level bans with specific end dates
}

enum BanStatus {
  PENDING // Awaiting approval
  APPROVED // Active ban
  DENIED // Rejected by approver
  EXPIRED // Past end date
}

enum BanDuration {
  ONE_MONTH
  THREE_MONTHS
  SIX_MONTHS
  ONE_YEAR
  TWO_YEARS
}

// ============================================
// VENUE-SPECIFIC BAN DETAILS
// ============================================

// This table allows each venue to have its own end date for a ban
model VenueBan {
  id        String   @id @default(uuid())
  banId     String
  venueId   String
  startDate DateTime @default(now())
  endDate   DateTime // Can be modified independently per venue
  isActive  Boolean  @default(true)

  ban   Ban   @relation(fields: [banId], references: [id], onDelete: Cascade)
  venue Venue @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@unique([banId, venueId])
}
